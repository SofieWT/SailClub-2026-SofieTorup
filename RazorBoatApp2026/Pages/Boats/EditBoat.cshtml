@page
@using SailClubLibrary.Models
@model RazorBoatApp2026.Pages.Boats.EditBoatModel
@{
    ViewData["Title"] = "Edit boat";
}
<h1>Edit boat</h1>

<form method="post">

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.Id" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.Id" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.Model" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.Model" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.SailNumber" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.SailNumber" readonly class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.TheBoatType" class="control-label"></label>
        <select asp-for="@Model.BoatToUpdate.TheBoatType" asp-items="Html.GetEnumSelectList<BoatType>()" class="form-control"></select>
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.Draft" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.Draft" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.Width" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.Width" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.Length" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.Length" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.BoatToUpdate.YearOfConstruction" class="control-label"></label>
        <input asp-for="@Model.BoatToUpdate.YearOfConstruction" class="form-control" />
    </div>

    <div class="form-group">
        <input type="submit" value="Update boat" class="btn-primary" />
        <input type="submit" value="Delete boat" asp-page-handler="Delete" class="btn-danger" />
        <input type="submit" value="Cancel" asp-page-handler="Cancel" class="btn-warning" />
    </div>

</form>
