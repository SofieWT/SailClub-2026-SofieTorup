@page
@using SailClubLibrary.Models
@model RazorBoatApp2026.Pages.Members.EditMemberModel
@{
    ViewData["Title"] = "Edit member";
}

<h1>Edit member</h1>

<form method="post">
    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.Id" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.Id" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.FirstName" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.FirstName" class="form-control"/>
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.SurName" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.SurName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.PhoneNumber" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.PhoneNumber" readonly class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.Mail" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.Mail" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.Address" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.Address" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.City" class="control-label"></label>
        <input asp-for="@Model.MemberToBeUpdated.City" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.TheMemberRole" class="control-label"></label>
        <select asp-for="@Model.MemberToBeUpdated.TheMemberRole" asp-items="Html.GetEnumSelectList<MemberRole>()" class="form-control"></select>
    </div>

    <div class="form-group">
        <label asp-for="@Model.MemberToBeUpdated.TheMemberType" class="control-label"></label>
        <select asp-for="@Model.MemberToBeUpdated.TheMemberType" asp-items="Html.GetEnumSelectList<MemberType>()" class="form-control"></select>
    </div>

    <div class="form-group">
        <input type="submit" value="Update member" class="btn-primary" />
        <input type="submit" value="Delete member" asp-page-handler="Delete" class="btn-danger" />
        <input type="submit" value="Cancel" asp-page-handler="Cancel" class="btn-warning" />
    </div>
</form>

