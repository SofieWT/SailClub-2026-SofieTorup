@page
@using SailClubLibrary.Models
@model RazorBoatApp2026.Pages.Members.CreateMemberModel
@{
    ViewData["Title"] = "Create member";
}
<h1>Create a member</h1>

<form method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div>
        <label asp-for="@Model.NewMember.Id" class="control-label"></label>
        <input asp-for="@Model.NewMember.Id" class="form-control" />

    </div>

    <div>
        <label asp-for="@Model.NewMember.FirstName" class="control-label"></label>
        <input asp-for="@Model.NewMember.FirstName" class="form-control" />
        <span asp-validation-for="@Model.NewMember.FirstName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="@Model.NewMember.SurName" class="control-label"></label>
        <input asp-for="@Model.NewMember.SurName" class="form-control" />
    </div>

    <div>
        <label asp-for="@Model.NewMember.PhoneNumber" class="control-label"></label>
        <input asp-for="@Model.NewMember.PhoneNumber" class="form-control" />
        <span asp-validation-for="@Model.NewMember.PhoneNumber" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="@Model.NewMember.Mail" class="control-label"></label>
        <input asp-for="@Model.NewMember.Mail" class="form-control" />
    </div>

    <div>
        <label asp-for="@Model.NewMember.Address" class="control-label"></label>
        <input asp-for="@Model.NewMember.Address" class="form-control" />
    </div>

    <div>
        <label asp-for="@Model.NewMember.City" class="control-label"></label>
        <input asp-for="@Model.NewMember.City" class="form-control" />
    </div>

    <div>
        <label asp-for="@Model.NewMember.TheMemberType" class="control-label"></label>
        <select asp-for="@Model.NewMember.TheMemberType" asp-items="Html.GetEnumSelectList<MemberType>()" class="form-control"></select>
    </div>

    <div>
        <label asp-for="@Model.NewMember.TheMemberRole" class="control-label"></label>
        <select asp-for="@Model.NewMember.TheMemberRole" asp-items="Html.GetEnumSelectList<MemberRole>()" class="form-control"></select>
    </div>

    <div class ="form-group">
        <input type="submit" value="Create member" class="btn-primary" />
    </div>

    <div>
        <a asp-page="Index">back to list of members</a>
    </div>
</form>
